---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import DemoPreview from '../components/DemoPreview.astro';
---

<Layout>
  <div class="relative">
    <div class="absolute top-4 left-4 z-50">
      <img src="/icons.svg" alt="App icon" class="h-12 w-12" />
    </div>
  <Hero />

  <section class="bg-dark py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-white mb-4 text-center">Interactive Demo</h2>
      <p class="text-gray-400 text-center mb-12">See ShowTime Lite in action with a static preview.</p>
      <DemoPreview />
    </div>
  </section>

  <section class="bg-[#111] py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Cloud‑First, Always Updated</h2>
      <p class="text-gray-300 mb-8">
        No downloads, no installs. Create slides directly in your browser and export
        to PDF, PNG, or JSON. Cloud storage keeps your work safe.
      </p>
      <a href="/demo" class="inline-block px-6 py-3 bg-primary text-white rounded-lg font-semibold hover:bg-opacity-90 transition">
        Get Started
      </a>
    </div>
  </section>
</div>
</Layout>