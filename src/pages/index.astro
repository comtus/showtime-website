---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import DemoPreview from '../components/DemoPreview.astro';
---

<Layout>
  <div class="relative">
  <Hero />

  <section id="demo" class="scroll-mt-20 bg-dark px-6 py-14">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-white mb-4 text-center">Interactive Demo</h2>
      <p class="text-gray-400 text-center mb-8">See ShowTime Lite in action with a static preview.</p>
      <DemoPreview />
    </div>
  </section>

  <section id="roadmap" class="scroll-mt-20 bg-[#111] px-6 py-16">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <h2 class="text-4xl font-bold text-white mb-4">Cloud-first today, desktop next</h2>
        <p class="text-lg text-gray-300">
          Create slides directly in the browser, export to PNG, PDF, or JSON, and follow the path toward offline editing and team workflows.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        <div class="rounded-lg border border-gray-700 bg-dark p-6">
          <h3 class="text-xl font-bold text-white mb-4">What’s here today</h3>
          <ul class="space-y-2 text-gray-300">
            <li>Cloud-based slide editor</li>
            <li>Dark and light themes</li>
            <li>Export to PNG, PDF, JSON</li>
            <li>Charts, diagrams, and code blocks</li>
            <li>Presentation mode</li>
          </ul>
        </div>

        <div class="rounded-lg border border-gray-700 bg-dark p-6">
          <h3 class="text-xl font-bold text-white mb-4">Coming soon</h3>
          <ul class="space-y-3 text-gray-300">
            <li><span class="text-primary font-semibold">Q3 2026</span> Desktop app with offline support</li>
            <li><span class="text-primary font-semibold">Q4 2026</span> Real-time collaboration</li>
            <li><span class="text-primary font-semibold">2027</span> Custom themes and AI-powered templates</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="pricing" class="scroll-mt-20 px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 max-w-2xl">
        <h2 class="text-4xl font-bold text-white mb-4">Pricing and access</h2>
        <p class="text-lg text-gray-300">
          Start with the free plan now. Pro and Enterprise access will open as collaboration and desktop features ship.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        <div class="rounded-lg border border-primary/60 bg-[#111] p-6">
          <h3 class="text-2xl font-bold text-white mb-2">Free</h3>
          <p class="text-4xl font-bold text-primary mb-5">$0 <span class="text-base text-gray-400">/ month</span></p>
          <ul class="mb-6 space-y-2 text-gray-300">
            <li>Create and export slides</li>
            <li>Basic templates</li>
            <li>PNG and PDF export</li>
            <li>Community support</li>
          </ul>
          <a href="https://showtime-lite.vercel.app/guest" target="_blank" rel="noopener noreferrer" class="inline-block w-full rounded-lg bg-primary px-5 py-3 text-center font-semibold text-white transition hover:bg-opacity-90">
            Sign In / Start Free
          </a>
        </div>

        <div class="rounded-lg border border-gray-700 bg-[#111] p-6">
          <h3 class="text-2xl font-bold text-white mb-2">Pro</h3>
          <p class="text-4xl font-bold text-gray-500 mb-5">Soon</p>
          <ul class="mb-6 space-y-2 text-gray-500">
            <li>Advanced themes and templates</li>
            <li>Cloud storage and history</li>
            <li>Priority support</li>
          </ul>
          <button disabled class="w-full rounded-lg bg-gray-800 px-5 py-3 font-semibold text-gray-500 cursor-not-allowed">Coming Soon</button>
        </div>

        <div class="rounded-lg border border-gray-700 bg-[#111] p-6">
          <h3 class="text-2xl font-bold text-white mb-2">Enterprise</h3>
          <p class="text-4xl font-bold text-gray-500 mb-5">Soon</p>
          <ul class="mb-6 space-y-2 text-gray-500">
            <li>Team accounts</li>
            <li>Real-time collaboration</li>
            <li>Deployment and support options</li>
          </ul>
          <button disabled class="w-full rounded-lg bg-gray-800 px-5 py-3 font-semibold text-gray-500 cursor-not-allowed">Coming Soon</button>
        </div>
      </div>
    </div>
  </section>

  <script>
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const easeOutBack = (progress) => {
      const overshoot = 1.35;
      const shifted = progress - 1;
      return 1 + shifted * shifted * ((overshoot + 1) * shifted + overshoot);
    };

    const scrollToSection = (target) => {
      const headerOffset = 88;
      const startY = window.scrollY;
      const targetY = target.getBoundingClientRect().top + startY - headerOffset;
      const distance = targetY - startY;
      const duration = 760;
      const startTime = performance.now();

      const animate = (now) => {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        window.scrollTo(0, startY + distance * easeOutBack(progress));

        if (progress < 1) {
          requestAnimationFrame(animate);
        } else {
          window.scrollTo(0, targetY);
        }
      };

      requestAnimationFrame(animate);
    };

    document.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener('click', (event) => {
        const hash = link.getAttribute('href');
        if (!hash || hash === '#') return;

        const target = document.querySelector(hash);
        if (!target) return;

        event.preventDefault();
        history.pushState(null, '', hash);

        if (prefersReducedMotion.matches) {
          target.scrollIntoView();
          return;
        }

        scrollToSection(target);
      });
    });
  </script>
</div>
</Layout>
