---
import { Logo } from '../components/Logo.astro';
---

<Layout>
  <header class="flex justify-between items-center p-6">
    <Logo />
    <nav class="space-x-4">
      <a href="/" class="text-gray-300 hover:text-primary transition">Home</a>
      <a href="/demo" class="text-gray-300 hover:text-primary transition">Demo</a>
    </nav>
  </header>

  <section class="min-h-[80vh] flex flex-col items-center justify-center px-6 py-24">
    <h1 class="text-5xl font-bold text-white mb-4">Pricing</h1>
    <p class="text-xl text-gray-300 mb-16 max-w-lg text-center">
      Free tier available now. Paid tiers with advanced features are coming soon.
    </p>

    <div class="grid gap-8 md:grid-cols-2 max-w-4xl w-full">
      <div class="bg-[#111] p-8 rounded-lg border border-gray-700">
        <h2 class="text-2xl font-bold text-white mb-4">Free</h2>
        <p class="text-4xl font-bold text-primary mb-6">$0 / month</p>
        <ul class="space-y-3 text-gray-300 mb-8">
          <li>✓ Create & export slides</li>
          <li>✓ Basic templates</li>
          <li>✓ Export to PNG & PDF</li>
          <li>✓ Community support</li>
        </ul>
        <a href="/demo" class="block text-center px-6 py-3 border border-primary text-primary rounded-lg font-semibold hover:bg-primary hover:text-white transition">
          Start Free
        </a>
      </div>

      <div class="bg-[#111] p-8 rounded-lg border border-gray-700">
        <h2 class="text-2xl font-bold text-white mb-4">Pro <span class="text-sm text-gray-500">Coming Soon</span></h2>
        <p class="text-4xl font-bold text-gray-500 mb-6">$– / month</p>
        <ul class="space-y-3 text-gray-500 mb-8">
          <li>– Advanced themes & templates</li>
          <li>– Team collaboration</li>
          <li>– Cloud storage & history</li>
          <li>– Priority support</li>
        </ul>
        <span class="inline-block px-6 py-3 bg-gray-800 text-gray-500 rounded-lg font-semibold cursor-not-allowed">
          Notify Me
        </span>
      </div>
    </div>

    <p class="mt-12 text-sm text-gray-500 text-center">
      Desktop app with richer features is in development. Stay tuned!
    </p>
  </section>
</Layout>