---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
---

<Layout>
  <header class="flex justify-between items-center p-6">
    <Logo />
    <nav class="space-x-4">
      <a href="/" class="text-gray-300 hover:text-primary transition">Home</a>
      <a href="/demo" class="text-gray-300 hover:text-primary transition">Demo</a>
      <a href="/pricing" class="text-gray-300 hover:text-primary transition">Pricing</a>
    </nav>
  </header>

  <section class="min-h-[80vh] flex flex-col items-center justify-center px-6 py-24">
    <h1 class="text-5xl font-bold text-white mb-4">Roadmap</h1>
    <p class="text-xl text-gray-300 mb-16 max-w-lg text-center">
      Here's where we're headed. Stay tuned for updates.
    </p>

    <div class="max-w-4xl w-full space-y-8">
      <!-- Current -->
      <div class="bg-[#111] p-8 rounded-lg border border-gray-700">
        <h2 class="text-2xl font-bold text-white mb-4">✅ What's Here Today</h2>
        <ul class="space-y-2 text-gray-300">
          <li>• Cloud‑based slide editor</li>
          <li>• Dark & light themes</li>
          <li>• Export to PNG, PDF, JSON</li>
          <li>• Rich component library (charts, diagrams, code blocks)</li>
          <li>• Presentation mode</li>
        </ul>
      </div>

      <!-- Future milestones -->
      <div class="bg-[#111] p-8 rounded-lg border border-gray-700">
        <h2 class="text-2xl font-bold text-white mb-4">🚀 Coming Soon</h2>
        <ul class="space-y-3 text-gray-300">
          <li>
            <span class="text-primary font-semibold">Q3 2026</span> — Desktop app with offline support
          </li>
          <li>
            <span class="text-primary font-semibold">Q4 2026</span> — Real‑time collaboration
          </li>
          <li>
            <span class="text-primary font-semibold">2027</span> — Custom themes & AI‑powered templates
          </li>
        </ul>
      </div>

      <!-- Teaser -->
      <div class="bg-[#111] p-8 rounded-lg border border-gray-700">
        <h2 class="text-2xl font-bold text-white mb-4">💡 Desktop App Teaser</h2>
        <p class="text-gray-300">
          A dedicated desktop client is in development. It will bring richer features,
          offline editing, and deeper integration with your local workflow.
        </p>
      </div>
    </div>

    <a href="/" class="mt-12 inline-block px-6 py-3 bg-primary text-white rounded-lg font-semibold hover:bg-opacity-90 transition">
      ← Back to Home
    </a>
  </section>
</Layout>