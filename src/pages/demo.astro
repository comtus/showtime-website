---
import { Logo } from '../components/Logo.astro';
---

<Layout>
  <header class="flex justify-between items-center p-6">
    <Logo />
    <nav class="space-x-4">
      <a href="/" class="text-gray-300 hover:text-primary transition">Home</a>
      <a href="/pricing" class="text-gray-300 hover:text-primary transition">Pricing</a>
    </nav>
  </header>

  <section class="min-h-[70vh] flex flex-col items-center justify-center px-6 py-24">
    <h1 class="text-5xl font-bold text-white mb-8">Interactive Demo</h1>
    <p class="text-xl text-gray-300 mb-12 max-w-lg text-center">
      Explore ShowTime Lite’s live editor in your browser.
      Full‑screen sandbox – no account needed.
    </p>

    <div class="w-full max-w-5xl rounded-lg border border-gray-700 overflow-hidden shadow-2xl">
      <iframe
        src="https://demo.showtime-lite.com"
        class="w-full h-[600px]"
        sandbox="allow-scripts allow-same-origin allow-forms"
        title="ShowTime Lite Demo"
      />
    </div>

    <p class="mt-6 text-sm text-gray-500">
      ← Coming soon: full‑screen navigation and video walkthrough.
    </p>
  </section>
</Layout>