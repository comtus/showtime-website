---
/**
 * Static image preview for demo section.
 * Uses st-lite_screenshot.jpg as demo image.
 */
const demoSrc = "/st-lite_screenshot.jpg";
---

<div class="relative w-full max-w-4xl mx-auto">
  <img
    src={demoSrc}
    alt="ShowTime Lite interactive demo screenshot"
    class="w-full rounded-lg shadow-xl"
  />
  <a
    href="/demo"
    class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-40 opacity-0 hover:opacity-100 transition-opacity rounded-lg"
  >
    <span class="rounded-lg bg-primary px-5 py-3 text-2xl font-bold text-dark">Launch Interactive Demo</span>
  </a>
</div>
