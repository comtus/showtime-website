---
import Logo from '../components/Logo.astro';
---

<section class="relative min-h-screen bg-[#0d0d0d] px-6 pt-20">
  <header class="fixed top-0 left-0 right-0 z-[100] border-b border-white/10 bg-[#0d0d0d]/35 backdrop-blur-xl">
    <div class="relative flex min-h-20 items-center px-4 sm:px-6">
      <a href="/" class="absolute left-4 top-1/2 -translate-y-1/2 sm:left-6" aria-label="ShowTime Lite home">
        <img src="/icons.svg" alt="" class="h-9 w-9 shrink-0" />
      </a>

      <a href="/" class="absolute left-1/2 top-1/2 hidden -translate-x-1/2 -translate-y-1/2 sm:block" aria-label="ShowTime Lite home">
        <Logo />
      </a>

      <nav class="ml-auto flex items-center gap-3 text-sm sm:gap-5 sm:text-base">
        <a href="#demo" class="text-gray-300 hover:text-primary transition">Demo</a>
        <a href="#pricing" class="text-gray-300 hover:text-primary transition">Pricing</a>
        <a href="#roadmap" class="text-gray-300 hover:text-primary transition">Roadmap</a>
        <a href="#pricing" class="rounded-md bg-primary px-3 py-2 font-bold text-dark transition hover:bg-opacity-90">Sign In</a>
      </nav>
    </div>
  </header>

  <div class="mx-auto flex min-h-[calc(100svh-5rem)] max-w-3xl flex-col items-center justify-center text-center">
    <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
      Modern Presentations <br class="hidden md:block" />
      <span class="text-primary">in Your Browser</span>
    </h1>
    <p class="text-xl text-gray-300 mb-12">
      ShowTime Lite is a cloud-based slide creation tool that lets you design stunning presentations
      with real-time preview and export capabilities. No install required – just create, collaborate,
      and share.
    </p>
    <div class="flex gap-4 justify-center">
      <a href="#demo" class="px-6 py-3 bg-primary text-dark rounded-lg font-bold hover:bg-opacity-90 transition">Try Demo</a>
      <a href="#pricing" class="px-6 py-3 border border-white bg-secondary text-dark rounded-lg font-bold hover:bg-white transition">View Pricing</a>
    </div>
  </div>
</section>
